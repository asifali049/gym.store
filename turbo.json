{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env", "**/.env.local"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": { "dependsOn": ["^build", "db:generate"], "outputs": [".next/**", "!.next/cache/**", "dist/**"] },
    "dev": { "dependsOn": ["db:generate"], "cache": false, "persistent": true },
    "start": { "dependsOn": ["build"], "cache": false, "persistent": true },
    "lint": { "dependsOn": ["^lint"], "outputs": [] },
    "type-check": { "dependsOn": ["^type-check", "db:generate"], "outputs": [] },
    "clean": { "cache": false },
    "db:generate": { "cache": false, "outputs": ["node_modules/.prisma/**"] },
    "db:migrate": { "cache": false },
    "db:studio": { "cache": false, "persistent": true }
  }
}
